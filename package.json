{
  "name": "summit-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "Summit Autopilot Agent for Loot Survivor",
  "scripts": {
    "start": "tsx src/index.ts",
    "cockpit": "tsx src/cockpit/server.ts",
    "cockpit:public": "COCKPIT_PUBLIC_MODE=1 tsx src/cockpit/server.ts",
    "cockpit:user": "COCKPIT_PUBLIC_MODE=1 COCKPIT_HOST=127.0.0.1 tsx src/cockpit/server.ts",
    "cockpit:tunnel": "npx -y localtunnel --port 8788 --subdomain fenrirsummit",
    "bootstrap": "NODE_OPTIONS='--experimental-wasm-modules --dns-result-order=ipv4first' tsx src/bootstrap/create-session.ts",
    "bootstrap:lean": "NODE_OPTIONS='--experimental-wasm-modules --dns-result-order=ipv4first' tsx src/bootstrap/create-session-lean.ts",
    "status": "tsx src/cli/status.ts",
    "beasts": "tsx src/cli/beasts.ts",
    "diplomacy": "tsx src/cli/diplomacy-scout.ts",
    "probe:lean": "tsx src/cli/probe-attack-lean.ts",
    "buy": "NODE_OPTIONS='--experimental-wasm-modules' tsx src/cli/market-buy.ts"
  },
  "dependencies": {
    "@cartridge/controller": "^0.13.9",
    "@cartridge/controller-wasm": "^0.9.4",
    "@cartridge/presets": "^0.5.4",
    "starknet": "^6.23.1",
    "ws": "^8.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
